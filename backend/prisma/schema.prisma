generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id          String   @id @default(uuid())
  title       String
  author      String
  description String   @db.Text
  content     String?  @db.Text
  publishedAt DateTime
  coverUrl    String?
  createdAt   DateTime @default(now())
}
